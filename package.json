{
  "name": "playwright-typescript-framework",
  "version": "1.0.0",
  "scripts": {
    "test": "cross-env ENV=dev playwright test",
    "test:dev": "cross-env ENV=dev playwright test",
    "test:qa": "cross-env ENV=qa playwright test",
    "test:headed-dev": "cross-env ENV=dev playwright test --headed",
    "test:headed-qa": "cross-env ENV=qa playwright test --headed",
    "test:debug": "cross-env ENV=dev playwright test --debug",
    "test:ui": "cross-env ENV=dev playwright test --ui",
    "test:chromium": "cross-env ENV=dev playwright test --project=chromium",
    "report": "playwright show-report ./reports",
    "allure:generate": "allure generate allure-results --clean",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^25.9.3",
    "allure-playwright": "^3.10.0",
    "cross-env": "^7.0.3",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "otplib": "^13.4.1",
    "winston": "^3.19.0"
  }
}
